# ──────────────────────────────────────────────────────────────────
# websites-portal-web — local env
# Copy to `.env` and tweak for your machine.
# ──────────────────────────────────────────────────────────────────

# Run against a local fixture instead of Odoo.
# Set to 1 when developing blocks / site chrome without a backend.
# Unset (or 0) in production.
NEXT_PUBLIC_USE_FIXTURES=1

# Backend Odoo URL (only used when NEXT_PUBLIC_USE_FIXTURES is 0).
ODOO_URL=https://portal.way4tech.com
